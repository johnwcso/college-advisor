{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "action.schema.json",
  "title": "AutoImproveAction",
  "description": "Structured action proposals emitted by auto_improve.py for review",
  "type": "object",
  "required": ["run_id", "generated_at", "actions"],
  "properties": {
    "run_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "priority", "reason"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "crawl_seed_add",
              "crawl_seed_remove",
              "regex_update",
              "recrawl_frequency_change",
              "student_list_flag",
              "verification_alert",
              "content_drift_alert"
            ]
          },
          "college": { "type": "string" },
          "student_id": { "type": "string" },
          "priority": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "reason": { "type": "string" },
          "proposed_value": {},
          "current_value": {},
          "auto_apply": { "type": "boolean", "default": false }
        }
      }
    }
  }
}
